# MiniMax API Key (Anthropic-compatible gateway) — 默认产品
# https://platform.minimaxi.com/ 或国际站 platform.minimax.io
ANTHROPIC_API_KEY=your_minimax_key
# 可选别名：PACODE_API_KEY

# Anthropic-compatible base URL（默认国内站）
ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic
# 国际站：https://api.minimax.io/anthropic
# DeepSeek：https://api.deepseek.com/anthropic
# 豆包 Coding：https://ark.cn-beijing.volces.com/api/coding
# 智谱 GLM：https://open.bigmodel.cn/api/anthropic
# 腾讯混元：https://api.hunyuan.cloud.tencent.com/anthropic
# 阿里千问：https://dashscope.aliyuncs.com/apps/anthropic
# 可选别名：PACODE_BASE_URL

# Default model
CLAUDE_MODEL=MiniMax-M3
# DeepSeek 例：deepseek-v4-pro
# 豆包例：ark-code-latest
# 智谱例：glm-5.2
# 混元例：hunyuan-2.0-thinking-20251109
# 千问例：qwen3-coder-plus
# 可选别名：PACODE_MODEL

# 鉴权方式：api-key（默认）| bearer（Token Plan / Coding Plan / 豆包）
# PACODE_AUTH_STYLE=api-key

# 套餐形态：api | token-plan | coding-plan
# PACODE_PLAN_MODE=token-plan

# 协议：anthropic（默认）| openai（官方 / Ollama / Models.dev）
# PACODE_API_PROTOCOL=openai
# OPENAI_API_KEY=
# OPENAI_BASE_URL=http://127.0.0.1:11434/v1

# Optional: Default max tokens
CLAUDE_MAX_TOKENS=8192

# 推荐：
#   pacode cc-switch presets --plan=token-plan
#   pacode cc-switch add tp --plan=token-plan --api-key=xxx
#   pacode cc-switch import --from=cc-switch
