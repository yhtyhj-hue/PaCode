# MiniMax API Key (Anthropic-compatible gateway)
# https://platform.minimaxi.com/ 或国际站 platform.minimax.io
ANTHROPIC_API_KEY=your_minimax_key
# 可选别名：PACODE_API_KEY

# Anthropic-compatible base URL（默认国内站）
ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic
# 国际站：https://api.minimax.io/anthropic
# 可选别名：PACODE_BASE_URL

# Default model
CLAUDE_MODEL=MiniMax-M3
# 可选别名：PACODE_MODEL

# Optional: Default max tokens
CLAUDE_MAX_TOKENS=8192
