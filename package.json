{
  "name": "pacode",
  "version": "0.1.0",
  "description": "Claude Code-like AI programming assistant framework. Source-available under BUSL-1.1 — personal/non-production use free; production use by any organization (including employee use) requires a commercial license. See LICENSE.",
  "type": "module",
  "bin": {
    "pacode": "./dist/cli/index.js"
  },
  "main": "./dist/sdk/index.js",
  "types": "./dist/sdk/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/sdk/index.d.ts",
      "import": "./dist/sdk/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "start": "node dist/cli/index.js",
    "dev": "node dist/cli/index.js",
    "test": "vitest run --exclude 'evals/periodic/**'",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --exclude 'evals/periodic/**'",
    "eval:gate": "vitest run evals/gate",
    "eval:periodic": "vitest run evals/periodic",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "test:all": "vitest run"
  },
  "keywords": [
    "claude",
    "ai",
    "agent",
    "programming",
    "assistant"
  ],
  "author": "",
  "license": "BUSL-1.1",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "diff": "^5.0.0",
    "figlet": "^1.11.0",
    "glob": "^10.0.0",
    "ink": "^5.0.0",
    "react": "^18.0.0",
    "string-width": "^7.2.0",
    "ws": "^8.21.1",
    "yaml": "^2.0.0",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@types/diff": "^5.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "eslint": "^8.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
